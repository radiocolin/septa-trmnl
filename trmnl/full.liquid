<div class="view view--full">
  <div class="title_bar">
    <span class="title">Route {{ route }} &nbsp;&bull;&nbsp; {{ stop_name }}</span>
    <span class="instance">Updated {{ updated_at }}</span>
  </div>

  <div class="layout layout--col layout--stretch">
    <div class="flex flex--stretch grow">
      {% for departure in departures limit:2 %}
        <div class="flex flex--col flex--center-x border rounded grow">
          <span class="value value--xlarge">{{ departure.time }}</span>
          <span class="label">{{ departure.status }}</span>
        </div>
      {% endfor %}
    </div>
    <div class="flex flex--stretch grow">
      {% for departure in departures offset:2 limit:2 %}
        <div class="flex flex--col flex--center-x border rounded grow">
          <span class="value value--xlarge">{{ departure.time }}</span>
          <span class="label">{{ departure.status }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
