<div class="view view--full flex flex-col p-4 bg-white text-black">
  <!-- Header -->
  <div class="flex items-center justify-between border-b-2 border-black pb-2 mb-4">
    <div class="flex items-center gap-3">
      <div class="bg-black text-white px-3 py-1 text-4xl font-bold rounded">
        {{ route }}
      </div>
      <div class="text-3xl font-bold truncate max-w-md">
        {{ stop_name }}
      </div>
    </div>
    <div class="text-2xl font-medium">
      Updated {{ updated_at }}
    </div>
  </div>

  <!-- Departures List -->
  <div class="flex flex-col gap-2">
    {% for departure in departures %}
      <div class="flex items-center justify-between py-2 border-b border-gray-200 last:border-0">
        <div class="flex items-center gap-4">
          <!-- Time -->
          <div class="text-5xl font-bold w-32">
            {{ departure.time }}
          </div>
          
          <!-- Headsign and Status -->
          <div class="flex flex-col">
            <div class="text-3xl font-bold truncate max-w-lg">
              {{ departure.headsign }}
            </div>
            <div class="text-xl text-gray-600 flex items-center gap-2">
              {% if departure.is_live %}
                <span class="w-3 h-3 bg-black rounded-full"></span>
                <span>{{ departure.status }}</span>
              {% else %}
                <span class="italic">Scheduled</span>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Delay Indicator -->
        {% if departure.is_live and departure.delay > 2 %}
          <div class="text-2xl font-bold">
            +{{ departure.delay }}m
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="flex items-center justify-center h-64 text-4xl text-gray-400 italic">
        No upcoming departures
      </div>
    {% endfor %}
  </div>

  <!-- Footer -->
  <div class="mt-auto flex justify-center text-xl text-gray-500 italic">
    SEPTA Real-time Data
  </div>
</div>
